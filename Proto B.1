                StoryEnabled              = true
                LastActivityTime          = tick()
                StoryBtn.Text             = "Running..."
                StoryBtn.BackgroundColor3 = RUNBG
                StoryBtn.TextColor3       = RUNT
                LockButton(DungeonBtn)
                DungeonBtn.Text             = "Auto Dungeon"
                DungeonBtn.BackgroundColor3 = BG3
                DungeonBtn.TextColor3       = TPRIM
                SetStatus("Auto-started (idle 5m)", RUNT)
                task.spawn(RunStoryLoop)
            end
        else
            LastActivityTime = tick()
        end
    end
end)


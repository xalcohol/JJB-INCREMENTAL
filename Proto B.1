-- ================================================================
-- [[ COMBAT READS ]] -- identical to Proto A
-- ================================================================
local function GetPlayerFighter(ctx)
    return SafeGet(ctx.Root(), "HealthbarArea","AlliesContainer","Fighter_Player")
end
local function GetEnemyFighter(ctx)
    return SafeGet(ctx.Root(), "HealthbarArea","EnemiesContainer","Fighter_Enemy")
end

local function IsInStoryBattle()
    return GetPlayerFighter(StoryCtx) ~= nil or GetEnemyFighter(StoryCtx) ~= nil
end
local function IsInDungeonBattle()
    return GetPlayerFighter(DungeonCtx) ~= nil and GetEnemyFighter(DungeonCtx) ~= nil
end

local function TryFleeFromDungeon()
    DungeonUseSkill("Flee")
    local logText = SafeGet(PlayerGui, table.unpack(DUNGEON_LOG_PATH))
    if not logText then task.wait(1); return false end
    local waited = 0
    while waited < 3 do
        if (logText.Text or ""):find("DUNGEON FLED!") then return true end
        task.wait(0.2); waited += 0.2
    end
    return false
end

local function GetResources(ctx)
    local label = SafeGet(ctx.Root(), "ResourceLabel")
    if not label then return 0, 0 end
    local text    = label.Text or ""
    local energy  = tonumber(text:match("ENERGY:%s*(%d+)"))  or 0
    local stamina = tonumber(text:match("STAMINA:%s*(%d+)")) or 0
    return energy, stamina
end

local function GetHP(ctx)
    local fighter = GetPlayerFighter(ctx)
    if not fighter then return 999, 999, 1 end
    local hpText = SafeGet(fighter, "InfoArea","HpContainer","HpText")
    if not hpText then return 999, 999, 1 end
    local cur, max = (hpText.Text or ""):match("(%d+)%s*/%s*(%d+)")
    cur = tonumber(cur) or 999; max = tonumber(max) or 999
    return cur, max, (max > 0 and cur / max or 1)
end

local function GetStatusDuration(fighter, statusName)
    if not fighter then return 0 end
    local container = SafeGet(fighter, "InfoArea","StatusContainer")
    if not container then return 0 end
    local lower = statusName:lower()
    for _, frame in ipairs(container:GetChildren()) do
        if frame:IsA("Frame") then
            local nameMatch  = frame.Name:lower() == lower
            local titleAttr  = frame:GetAttribute("Title")
            local titleMatch = titleAttr and tostring(titleAttr):lower() == lower
            if nameMatch or titleMatch then
                local durAttr = frame:GetAttribute("TooltipDur")
                if durAttr then return tonumber(durAttr) or 0 end
                local durLabel = frame:FindFirstChild("Duration")
                if durLabel and durLabel:IsA("TextLabel") then return tonumber(durLabel.Text) or 0 end
                return 1
            end
        end
    end
    return 0
end

local function FighterHasStatus(fighter, name) return GetStatusDuration(fighter, name) > 0 end
local function EnemyStatusDur(ctx, name)       return GetStatusDuration(GetEnemyFighter(ctx), name) end
local function IsPlayerIncapacitated(ctx)
    local f = GetPlayerFighter(ctx)
    return FighterHasStatus(f,"Stun") or FighterHasStatus(f,"Freeze")
end
local function IsConfused(ctx) return FighterHasStatus(GetPlayerFighter(ctx),"Confusion") end
local function EnemyHasStatus(ctx, name)  return FighterHasStatus(GetEnemyFighter(ctx), name)               end
local function EnemyIsStunImmune(ctx)     return EnemyHasStatus(ctx,"StunImmunity")                         end
local function EnemyIsConfImmune(ctx)     return EnemyHasStatus(ctx,"ConfImmunity")                         end
local function EnemyIsStunned(ctx)        return EnemyHasStatus(ctx,"Stun") or EnemyHasStatus(ctx,"Freeze") end
local function EnemyIsConfused(ctx)       return EnemyHasStatus(ctx,"Confusion")                            end
local function EnemyIsBurning(ctx)        return EnemyHasStatus(ctx,"Burn")                                 end

-- ================================================================
-- [[ MOVESET ]] -- identical to Proto A
-- ================================================================
local function GetMoveButton(ctx, skillName)
    local area = SafeGet(ctx.Root(), "AbilitiesArea")
    if not area then return nil end
    for _, btn in ipairs(area:GetChildren()) do
        if btn:IsA("TextButton") then
            local base = btn.Name:match("^(.-)%s*%(%d+%)%s*$") or btn.Name
            if base == skillName then return btn end
        end
    end
    return nil
end
local function CanUse(ctx, skillName)
    local btn = GetMoveButton(ctx, skillName)
    if not btn then return false end
    return not btn.Name:match("%(%d+%)")
end
local function UseSkill(ctx, name) ctx.UseSkill(name) end

-- ================================================================
-- [[ LOADOUT DETECTION ]] -- identical to Proto A
-- ================================================================
local function DetectLoadoutFromInventory()
    local styleNode = SafeGet(PlayerGui, table.unpack(INV_STYLE_PATH))
    local standNode = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
    if styleNode then
        local t = styleNode.Text or ""
        if     t:find("ULTIMATE LIFEFORM") then CurrentStyle = "ULF"
        elseif t:find("SHRINE")            then CurrentStyle = "Shrine"
        else                                    CurrentStyle = "Unknown" end
    end
    if standNode then CurrentStand = FormatStandLabel(standNode.Text or "") end
    UpdateLoadoutDisplay()
end

local function ConfirmLoadoutInCombat(ctx)
    local area = SafeGet(ctx.Root(), "AbilitiesArea")
    if not area then return end
    for _, btn in ipairs(area:GetChildren()) do
        if btn:IsA("TextButton") then
            local base = btn.Name:match("^(.-)%s*%(%d+%)%s*$") or btn.Name
            for _, data in pairs(LOADOUT.Style) do
                if base == data.signature then CurrentStyle = data.label end
            end
            for _, data in pairs(LOADOUT.Stand) do
                if base == data.signature then
                    local standNode = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
                    if standNode then CurrentStand = FormatStandLabel(standNode.Text or "")
                    else              CurrentStand = data.label end
                end
            end
        end
    end
    UpdateLoadoutDisplay()
end

-- ================================================================
-- [[ LOADOUT ENFORCEMENT ]]
-- ================================================================
local function FleeAnyActiveBattle()
    if IsInStoryBattle() then
        StoryUseSkill("Flee"); task.wait(1)
    elseif IsInDungeonBattle() then
        TryFleeFromDungeon(); task.wait(0.5)
    end
end

local function EnsureStyle(targetStyle)
    local fullName = targetStyle
    if targetStyle == "ULF" then fullName = "Ultimate Lifeform" end

    local function styleMatches()
        if targetStyle == "ULF" and CurrentStyle == "ULF" then return true end
        if CurrentStyle:lower() == fullName:lower() then return true end
        return false
    end

    if styleMatches() then return end
    FleeAnyActiveBattle()
    local slot = FindStyleSlotByName(fullName)
    if slot then SwapStyle(slot) else SwapStyle(1) end
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited += 0.3
        DetectLoadoutFromInventory()
        if styleMatches() then return end
    end
end

local function EnsureStand(targetStand)
    if CurrentStand:upper():find(targetStand:upper(), 1, true) then return end
    local slot = FindStandSlotByName(targetStand)
    if not slot then return end
    FleeAnyActiveBattle()
    SwapStand(slot)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited += 0.3
        DetectLoadoutFromInventory()
        if CurrentStand:upper():find(targetStand:upper(), 1, true) then return end
    end
end

local function EnforceStoryLoadout()
    if not IsInStoryBattle() then FleeAnyActiveBattle() end
    DetectLoadoutFromInventory()
    if CFG.storyStandName and CFG.storyStandName ~= "" then
        EnsureStand(CFG.storyStandName)
    end
    EnsureStyle("ULF")
end

local function EnforceDungeonLoadout()
    if not IsInDungeonBattle() then FleeAnyActiveBattle() end
    DetectLoadoutFromInventory()
    if CFG.dungeonStandName and CFG.dungeonStandName ~= "" then
        EnsureStand(CFG.dungeonStandName)
    end
    EnsureStyle("ULF")
end

-- ================================================================
-- [[ SURVIVAL CHECK ]] -- identical to Proto A
-- ================================================================
local function HandleSurvival(ctx)
    local _, _, hpPct = GetHP(ctx)
    if hpPct < HP_DANGER then
        if     CanUse(ctx,"Instant Reformation") then UseSkill(ctx,"Instant Reformation")
        elseif CanUse(ctx,"Block")               then UseSkill(ctx,"Block")
        else                                          UseSkill(ctx,"Rest") end
        return true
    end
    if hpPct < HP_HEAL then
        if CanUse(ctx,"Instant Reformation") then
            ctx.HasBlockedThisDip = false
            UseSkill(ctx,"Instant Reformation"); return true
        end
        if not ctx.HasBlockedThisDip then
            ctx.HasBlockedThisDip = true
            if CanUse(ctx,"Block") then UseSkill(ctx,"Block"); return true end
        end
    else
        ctx.HasBlockedThisDip = false
    end
    return false
end

-- ================================================================
-- [[ PRIORITY EXECUTION ]]
-- ================================================================
local function ExecutePriority(ctx, priorityList, energyThreshold)
    if not priorityList or #priorityList == 0 then return false end
    local threshold = energyThreshold or STORY_ENERGY_THRESHOLD
    local energy, stamina = GetResources(ctx)

    local standName, styleKey
    if ctx == WorldBossCtx then
        standName = CFG.wbStandName; styleKey = CFG.wbStyleName
    elseif ctx == DungeonCtx then
        standName = CFG.dungeonStandName; styleKey = "Ultimate Lifeform"
    else
        standName = CFG.storyStandName; styleKey = "Ultimate Lifeform"
    end

    local moveMap = {}
    if standName and STAND_MOVES[standName] then
        for _, m in ipairs(STAND_MOVES[standName].moves) do moveMap[m.name] = m end
    end
    if styleKey and STYLE_MOVES[styleKey] then
        for _, m in ipairs(STYLE_MOVES[styleKey].moves) do moveMap[m.name] = m end
    end

    for _, moveName in ipairs(priorityList) do
        if CanUse(ctx, moveName) then
            local m = moveMap[moveName]
            local skip = false
            if m then
                if m.cost == "energy"  and energy  < threshold        then skip = true end
                if m.cost == "stamina" and stamina < STAMINA_THRESHOLD then skip = true end
                if not skip then
                    local st = m.statusType
                    if     st == "confusion" then if EnemyIsConfImmune(ctx) or EnemyIsConfused(ctx) then skip = true end
                    elseif st == "stun"      then if EnemyIsStunImmune(ctx) or EnemyIsStunned(ctx)  then skip = true end
                    elseif st == "burn"      then if EnemyStatusDur(ctx,"Burn")  > 1 then skip = true end
                    elseif st == "bleed"     then if EnemyStatusDur(ctx,"Bleed") > 1 then skip = true end
                    end
                end
            end
            if not skip then UseSkill(ctx, moveName); return true end
        end
    end
    return false
end

-- ================================================================
-- [[ STORY COMBAT ENGINE ]]
-- ================================================================
local function RunStoryCombatTick()
    local ctx             = StoryCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= STORY_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD
    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if IsTooru() then
        if #CFG.tooruPriority > 0 then
            if ExecutePriority(ctx, CFG.tooruPriority) then return end
        else
            if hasEnergy and CanUse(ctx,"Illusory Presence") then
                if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then UseSkill(ctx,"Illusory Presence"); return end
            end
            if hasEnergy and CanUse(ctx,"Rain of Debris") then UseSkill(ctx,"Rain of Debris"); return end
            if hasEnergy and CanUse(ctx,"Golden Spin") then
                if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then UseSkill(ctx,"Golden Spin"); return end
            end
            if hasStamina and CanUse(ctx,"Melting Overdrive") then
                if not EnemyIsBurning(ctx) then UseSkill(ctx,"Melting Overdrive"); return end
            end
        end
        if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
        UseSkill(ctx,"Rest"); return
    end

    if EnemyUsesPucciConfig() then
        if #CFG.pucciPriority > 0 then
            if ExecutePriority(ctx, CFG.pucciPriority) then return end
        else
            if hasEnergy and CanUse(ctx,"Illusory Presence") then
                if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then UseSkill(ctx,"Illusory Presence"); return end
            end
            if hasEnergy and CanUse(ctx,"Golden Spin") then
                if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then UseSkill(ctx,"Golden Spin"); return end
            end
        end
        if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
        UseSkill(ctx,"Rest"); return
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ DUNGEON COMBAT ENGINE ]]
-- ================================================================
local function RunDungeonCombatTick()
    local ctx             = DungeonCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= DUNGEON_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD
    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if #CFG.dungeonPriority > 0 then
        if ExecutePriority(ctx, CFG.dungeonPriority, DUNGEON_ENERGY_THRESHOLD) then return end
    else
        if hasEnergy and CanUse(ctx,"Illusory Presence") then
            if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then UseSkill(ctx,"Illusory Presence"); return end
        end
        if hasEnergy and CanUse(ctx,"Golden Spin") then
            if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then UseSkill(ctx,"Golden Spin"); return end
        end
        if hasStamina and CanUse(ctx,"Melting Overdrive") then
            if not EnemyIsBurning(ctx) then UseSkill(ctx,"Melting Overdrive"); return end
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
    if not hasEnergy and hasStamina then
        if CanUse(ctx,"Melting Overdrive") then UseSkill(ctx,"Melting Overdrive"); return end
        UseSkill(ctx,"Rest"); return
    end
    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ WORLD BOSS COMBAT ENGINE ]]
-- ================================================================
local function RunWorldBossTick()
    local ctx             = WorldBossCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= STORY_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD
    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if #CFG.wbPriority > 0 then
        if ExecutePriority(ctx, CFG.wbPriority) then return end
    else
        if hasEnergy and CanUse(ctx,"Illusory Presence") then
            if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then UseSkill(ctx,"Illusory Presence"); return end
        end
        if hasEnergy and CanUse(ctx,"Rain of Debris") then UseSkill(ctx,"Rain of Debris"); return end
        if hasEnergy and CanUse(ctx,"Golden Spin") then
            if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then UseSkill(ctx,"Golden Spin"); return end
        end
        if hasStamina and CanUse(ctx,"Malevolent Shrine") then
            if EnemyStatusDur(ctx,"Bleed") <= 1 then UseSkill(ctx,"Malevolent Shrine"); return end
        end
        if hasStamina and CanUse(ctx,"Divine Flame") then
            if EnemyStatusDur(ctx,"Burn") <= 1 then UseSkill(ctx,"Divine Flame"); return end
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
    if not hasEnergy and hasStamina then
        if     CanUse(ctx,"Malevolent Shrine") then UseSkill(ctx,"Malevolent Shrine"); return
        elseif CanUse(ctx,"Divine Flame")      then UseSkill(ctx,"Divine Flame");      return
        else                                        UseSkill(ctx,"Rest");              return end
    end
    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ BATTLE LOOPS ]] -- identical to Proto A
-- ================================================================
local function RunStoryBattleLoop(enabledFlag)
    StoryCtx.HasBlockedThisDip = false
    task.wait(0.5)
    ConfirmLoadoutInCombat(StoryCtx)
    while enabledFlag() and not ScriptKilled do
        if not IsInStoryBattle() then
            -- Combat just ended. If prestige should fire, do it NOW before
            -- the game auto-engages the next story.
            if PrestigeEnabled and ShouldPrestigeNow() then
                FirePrestige()
                task.wait(ACTION_CD)
                return
            end
            -- Not prestiging, exit loop normally
            break
        end
        RunStoryCombatTick()
        task.wait(ACTION_CD)
    end
    StoryCtx.HasBlockedThisDip = false
end

local function RunDungeonBattleLoop(enabledFlag)
    DungeonCtx.HasBlockedThisDip = false
    task.wait(0.5)
    ConfirmLoadoutInCombat(DungeonCtx)
    while enabledFlag() and not ScriptKilled and IsInDungeonBattle() do
        RunDungeonCombatTick(); task.wait(ACTION_CD)
    end
    DungeonCtx.HasBlockedThisDip = false
end

-- ================================================================
-- [[ WORLD BOSS HELPERS ]] -- identical to Proto A
-- ================================================================
local function ParseTimerLabel()
    local label = SafeGet(PlayerGui, table.unpack(WB_TIMER_PATH))
    if not label then return nil end
    local mins, secs = (label.Text or ""):match("(%d+):(%d+)")
    if not mins then return nil end
    return tonumber(mins) * 60 + tonumber(secs)
end

local function GetEngageBtnText()
    local btn = SafeGet(PlayerGui, table.unpack(WB_ENGAGE_PATH))
    return btn and (btn.Text or "") or ""
end

local function WaitForBossTimer()
    while StoryEnabled and not ScriptKilled do
        local secs = ParseTimerLabel()
        if not secs or secs <= 0 then return end
        if secs > 30 * 60 then
            local elapsed = 0
            while elapsed < 1800 and StoryEnabled and not ScriptKilled do task.wait(1); elapsed += 1 end
        elseif secs > 10 * 60 then
            local elapsed = 0
            while elapsed < 600 and StoryEnabled and not ScriptKilled do task.wait(1); elapsed += 1 end
        else
            local elapsed = 0
            while elapsed < secs and StoryEnabled and not ScriptKilled do task.wait(1); elapsed += 1 end
            return
        end
    end
end

local function RunWorldBossScanner()
    local engageText = GetEngageBtnText()
    if not engageText:find("ENGAGE BOSS") then WaitForBossTimer() end
    while StoryEnabled and not ScriptKilled do
        local et = GetEngageBtnText()
        if et:find("ENGAGE BOSS") then
            WorldBossPriority = true
            while WorldBossPriority and StoryEnabled and not ScriptKilled do task.wait(1) end
            task.wait(10); WaitForBossTimer()
        elseif et:find("ALREADY FOUGHT") then
            task.wait(5); WaitForBossTimer()
        else
            task.wait(5); WaitForBossTimer()
        end
    end
end

-- ================================================================
-- [[ WORLD BOSS FIGHT ]]
-- ================================================================
local function RunWorldBossFight()
    PreBossStand = CurrentStand
    PreBossStyle = CurrentStyle

    DetectLoadoutFromInventory()

    local wbStand = CFG.wbStandName or "Tusk of U"
    local wbStyle = CFG.wbStyleName or "Shrine"

    if CurrentStyle ~= wbStyle then
        local slot = FindStyleSlotByName(wbStyle)
        if slot then SwapStyle(slot) else SwapStyle(1) end
        local waited = 0
        while waited < 5 do
            task.wait(0.3); waited += 0.3
            DetectLoadoutFromInventory()
            if CurrentStyle == wbStyle then break end
        end
    end
    EnsureStand(wbStand)

    EngageWorldBoss()

    local turnLabel = SafeGet(PlayerGui, table.unpack(WB_TURN_PATH))
    local waited = 0; local fightStarted = false
    while waited < 8 and not ScriptKilled do
        task.wait(0.3); waited += 0.3
        if turnLabel and (turnLabel.Text or ""):find("Turns Remaining: 10/10") then
            fightStarted = true; break
        end
    end
    if not fightStarted then WorldBossUseSkill("Infinite Rotation"); task.wait(1) end

    local logText = SafeGet(PlayerGui, table.unpack(WB_LOG_PATH))
    WorldBossCtx.HasBlockedThisDip = false
    task.wait(0.5)
    ConfirmLoadoutInCombat(WorldBossCtx)

    local elapsed = 0
    while elapsed < 120 and not ScriptKilled do
        if logText then
            local log = logText.Text or ""
            if log:find("Damage Dealt:") or log:find("Loot Secured") then break end
        end
        RunWorldBossTick(); task.wait(ACTION_CD); elapsed += ACTION_CD
    end

    WorldBossCtx.HasBlockedThisDip = false

    if CurrentStyle ~= PreBossStyle then
        local slot = FindStyleSlotByName(PreBossStyle)
        if slot then SwapStyle(slot) else SwapStyle(1) end
        task.wait(0.5)
    end
    if not CurrentStand:upper():find(PreBossStand:upper(), 1, true) then
        local slot = FindStandSlotByName(PreBossStand)
        if slot then SwapStand(slot); task.wait(0.5) end
    end
    if CurrentStyle ~= PreBossStyle or not CurrentStand:upper():find(PreBossStand:upper(), 1, true) then
        DetectLoadoutFromInventory()
    end

    WorldBossPriority = false
end

-- ================================================================
-- [[ TRAINING + KEY PRESS ]]
-- ================================================================
local function PressGameKey(keyCode)
    local key = keyCode.Value
    if keypress then
        keypress(key); task.wait(0.05); keyrelease(key)
    else
        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.05)
        vim:SendKeyEvent(false, keyCode, false, game)
    end
end

local function EnsureTraining()
    -- Navigate to training page so the frame is active
    PressGameKey(Enum.KeyCode.Five)
    task.wait(1.5)
    -- Read the button - only fire if training is currently OFF
    local btn = SafeGet(PlayerGui, table.unpack(TRAINING_BTN_PATH))
    local text = btn and (btn.Text or "") or ""
    if text:find("Start Training") or text == "" then
        -- "Start Training" = off, fire once to turn on
        -- empty = couldn't read, fire once as best effort
        ToggleTraining:FireServer(true)
    end
    -- if "Stop Training" = already on, don't fire (would toggle it OFF)
    task.wait(0.5)
    PressGameKey(Enum.KeyCode.One)
    task.wait(0.5)
end

-- ================================================================
-- [[ AUTO STORY LOOP ]]
-- ================================================================
local function RunStoryLoop()
    PressGameKey(Enum.KeyCode.One)
    task.wait(0.3)

    EnforceStoryLoadout()
    TryFleeFromDungeon()
    task.wait(0.5)

    -- finish any combat already in progress on entry
    if IsInStoryBattle() then
        RunStoryBattleLoop(function() return StoryEnabled end)
        task.wait(ACTION_CD)
    end

    task.spawn(RunWorldBossScanner)

    while StoryEnabled and not ScriptKilled do
        if WorldBossPriority then
            if IsInStoryBattle() then
                RunStoryBattleLoop(function() return StoryEnabled end)
                task.wait(ACTION_CD)
            end
            RunWorldBossFight(); task.wait(ACTION_CD)

        elseif PrestigeEnabled and ShouldPrestigeNow() then
            -- Prestige is available: finish current combat if in one, then prestige
            if IsInStoryBattle() then
                RunStoryBattleLoop(function() return StoryEnabled end)
                task.wait(ACTION_CD)
            end
            FirePrestige(); task.wait(ACTION_CD)

        elseif PrestigeEnabled then
            -- Prestige mode on but not yet available: run stories normally
            CombatAction:FireServer("EngageStory"); task.wait(ACTION_CD)
            RunStoryBattleLoop(function() return StoryEnabled end)
            task.wait(ACTION_CD)

        else
            CombatAction:FireServer("EngageStory"); task.wait(ACTION_CD)
            RunStoryBattleLoop(function() return StoryEnabled end)
            task.wait(ACTION_CD)
        end

        task.wait(ACTION_CD)
    end
end

-- ================================================================
-- [[ AUTO DUNGEON LOOP ]]
-- ================================================================
local function RunDungeonLoop()
    -- ensure on story/dungeon/wb page
    PressGameKey(Enum.KeyCode.One)
    task.wait(0.5)

    -- Blind-fire story flee (safe if not in story)
    StoryUseSkill("Flee")
    task.wait(1)

    -- inline loadout enforcement without re-fleeing
    DetectLoadoutFromInventory()
    if CFG.dungeonStandName and CFG.dungeonStandName ~= "" then
        EnsureStand(CFG.dungeonStandName)
    end
    EnsureStyle("ULF")

    while DungeonEnabled and not ScriptKilled do
        if CFG.dailyModeOn and CFG.dailyFloor then
            local floorLabel = SafeGet(PlayerGui, table.unpack(DUNGEON_FLOOR_PATH))
            local floor = floorLabel and tonumber((floorLabel.Text or ""):match("Floor%s+(%d+)")) or 0
            if floor > CFG.dailyFloor then
                TryFleeFromDungeon(); task.wait(0.5)
                DungeonEnabled = false
                DungeonBtn.Text             = "Auto Dungeon"
                DungeonBtn.BackgroundColor3 = BG3
                DungeonBtn.TextColor3       = TPRIM
                UnlockButton(StoryBtn)
                StoryEnabled = true
                StoryBtn.Text             = "Running..."
                StoryBtn.BackgroundColor3 = RUNBG
                StoryBtn.TextColor3       = RUNT
                LockButton(DungeonBtn)
                SetStatus("Daily floor hit - switched to story", RUNT)
                task.spawn(RunStoryLoop)
                return
            end
        end

        if not IsInDungeonBattle() then
            StartDungeon()
            task.wait(ACTION_CD)
            local waited = 0
            while not IsInDungeonBattle() and waited < 5 do
                task.wait(0.2); waited += 0.2
            end
        end
        if IsInDungeonBattle() then
            RunDungeonBattleLoop(function() return DungeonEnabled end)
        end
        task.wait(ACTION_CD)
    end
end


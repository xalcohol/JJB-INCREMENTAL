local function UpdateLoadoutLabels()
    StandLabel.Text = "Stand: " .. CurrentStand
    StyleLabel.Text = "Style: " .. CurrentStyle
end

local function DetectLoadoutFromInventory()
    local styleNode = SafeGet(PlayerGui, table.unpack(INV_STYLE_PATH))
    local standNode = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
    if styleNode then
        local t = styleNode.Text or ""
        if     t:find("ULTIMATE LIFEFORM") then CurrentStyle = "ULF"
        elseif t:find("SHRINE")            then CurrentStyle = "Shrine"
        else                                    CurrentStyle = "Unknown" end
    end
    if standNode then
        local t = standNode.Text or ""
        if     t:find("TUSK ACT 4") then CurrentStand = "Tusk Act 4"
        elseif t:find("KING OF U")  then CurrentStand = "King of U"
        else                             CurrentStand = "Unknown" end
    end
    UpdateLoadoutLabels()
    -- print(string.format("[AutoJJBI] Loadout — Stand: %s | Style: %s", CurrentStand, CurrentStyle))
end

local function ConfirmLoadoutInCombat(ctx)
    local area = SafeGet(ctx.Root(), "AbilitiesArea")
    if not area then return end
    for _, btn in ipairs(area:GetChildren()) do
        if btn:IsA("TextButton") then
            local base = btn.Name:match("^(.-)%s*%(%d+%)%s*$") or btn.Name
            for _, data in pairs(LOADOUT.Style) do
                if base == data.signature then CurrentStyle = data.label end
            end
            for _, data in pairs(LOADOUT.Stand) do
                if base == data.signature then CurrentStand = data.label end
            end
        end
    end
    UpdateLoadoutLabels()
end

local function EnsureULFForStory()
    if CurrentStyle == "ULF" then return end
    -- warn("[Story] Style is not ULF — swapping.")
    SwapStyle(1)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited += 0.3
        DetectLoadoutFromInventory()
        if CurrentStyle == "ULF" then return end
    end
    -- warn("[Story] ULF swap timed out — proceeding.")
end

-- ================================================================
-- [[ COMBAT DECISION ENGINE (Story + Dungeon) ]]
-- ================================================================
local function RunCombatTick(ctx)
    local _, _, hpPct     = GetHP(ctx)
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end

    if hpPct < HP_DANGER then
        if     CanUse(ctx,"Instant Reformation") then UseSkill(ctx,"Instant Reformation")
        elseif CanUse(ctx,"Block")               then UseSkill(ctx,"Block")
        else                                          UseSkill(ctx,"Rest")
        end
        return
    end

    if hpPct < HP_HEAL then
        if CanUse(ctx,"Instant Reformation") then
            ctx.HasBlockedThisDip = false
            UseSkill(ctx,"Instant Reformation"); return
        end
        if not ctx.HasBlockedThisDip then
            ctx.HasBlockedThisDip = true
            if CanUse(ctx,"Block") then UseSkill(ctx,"Block"); return end
        end
    else
        ctx.HasBlockedThisDip = false
    end

    local hasEnergy  = energy  >= ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if hasEnergy and CanUse(ctx,"Illusory Presence") then
        if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
            UseSkill(ctx,"Illusory Presence"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Dimensional Slash") then
        if not EnemyIsBleeding(ctx) then
            UseSkill(ctx,"Dimensional Slash"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Rain of Debris") then
        UseSkill(ctx,"Rain of Debris"); return
    end

    if hasEnergy and CanUse(ctx,"Golden Spin") then
        if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
            UseSkill(ctx,"Golden Spin"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Cellular Destruction") then
        if not EnemyIsPoisoned(ctx) then
            UseSkill(ctx,"Cellular Destruction"); return
        end
    end

    if hasStamina and CanUse(ctx,"Melting Overdrive") then
        if not EnemyIsBurning(ctx) then
            UseSkill(ctx,"Melting Overdrive"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then
        UseSkill(ctx,"Infinite Rotation"); return
    end
    if hasEnergy and CanUse(ctx,"Raging Demon") then
        UseSkill(ctx,"Raging Demon"); return
    end

    if not hasEnergy and hasStamina then
        if CanUse(ctx,"Melting Overdrive") then UseSkill(ctx,"Melting Overdrive"); return end
        UseSkill(ctx,"Rest"); return
    end
    if hasEnergy and not hasStamina then
        if     CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return
        elseif CanUse(ctx,"Raging Demon")      then UseSkill(ctx,"Raging Demon");      return
        else                                        UseSkill(ctx,"Rest");               return
        end
    end

    UseSkill(ctx,"Rest")
end


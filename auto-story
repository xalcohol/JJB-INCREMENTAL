-- [[ STATE ]] --
local GrindEnabled   = false
local BossScanEnabled = false
local BossPriority   = false

-- [[ PATH HELPERS ]] --
local function SafeGet(root, ...)
    local current = root
    for _, name in ipairs({...}) do
        if not current then return nil end
        current = current:FindFirstChild(name)
    end
    return current
end

local function GetCombatRoot()
    return SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer",
        "SingleplayerFrame","MainPanel","InnerContent",
        "ContentArea","StoryFrame","CombatMainFrame","ContentContainer"
    )
end

local function IsInBattle()
    local root = GetCombatRoot()
    if not root then return false end
    local allies = SafeGet(root, "HealthbarArea", "AlliesContainer")
    return allies and allies:FindFirstChild("Fighter_Player") ~= nil
end

local function GetEnergy()
    local root = GetCombatRoot()
    if not root then return 0 end
    local label = root:FindFirstChild("ResourceLabel")
    if not label then return 0 end
    return tonumber((label.Text or ""):match("ENERGY:%s*(%d+)")) or 0
end

local function IsBokuNoRhythm()
    local btn = SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer",
        "SingleplayerFrame","MainPanel","InnerContent",
        "ContentArea","StoryFrame","CombatMainFrame","ContentContainer",
        "ButtonContainer","StoryEncounterBtn"
    )
    if not btn then return false end
    for _, obj in ipairs({ btn, table.unpack(btn:GetDescendants()) }) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            if (obj.Text or ""):find("Boku no Rhythm") then return true end
        end
    end
    return false
end

-- [[ WORLD BOSS DETECTION ]] --
local function IsWorldBossActive()
    return false
end

local function RunBossScanner()
    while GrindEnabled and BossScanEnabled and not ScriptKilled do
        if IsWorldBossActive() then
            if not BossPriority then
                warn("[AutoStory] World Boss detected — taking priority.")
            end
            BossPriority = true
        else
            BossPriority = false
        end
        task.wait(ACTION_CD)
    end
    BossPriority = false
end

-- [[ CORE ACTIONS ]] --
local function TryPrestige()
    FirePrestige()
    task.wait(ACTION_CD)
end

-- [[ BATTLE LOOP ]] --
local function RunBattleLoop()
    while GrindEnabled and not ScriptKilled and IsInBattle() do
        if GetEnergy() >= 15 then
            FireCombat("Attack", { SkillName = "Infinite Rotation" })
        else
            FireCombat("Attack", { SkillName = "Rest" })
        end
        task.wait(ACTION_CD)
    end
end

-- [[ MAIN GRIND LOOP ]] --
local function RunGrindLoop()
    if IsInBattle() then
        warn("[AutoStory] Already in battle on start — finishing current fight first.")
        RunBattleLoop()
        task.wait(ACTION_CD)
    end

    TryPrestige()
    task.wait(ACTION_CD)

    while GrindEnabled and not ScriptKilled do

        if BossScanEnabled and BossPriority then
            warn("[AutoStory] Waiting on World Boss fight...")
            task.wait(ACTION_CD)

        elseif IsBokuNoRhythm() then
            warn("[AutoStory] Boku no Rhythm reached — Prestiging.")
            TryPrestige()
            task.wait(ACTION_CD)

        else
            FireCombat("EngageStory")
            task.wait(ACTION_CD)
            RunBattleLoop()
            task.wait(ACTION_CD)
        end

        task.wait(ACTION_CD)
    end
end

-- [[ TOGGLE GRIND ]] --
ToggleBtn.MouseButton1Click:Connect(function()
    if ScriptKilled then return end
    GrindEnabled = not GrindEnabled

    if GrindEnabled then
        ToggleBtn.Text = "||  Auto Grinding"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 70, 40)
        ToggleBtn.TextColor3 = Color3.fromRGB(120, 255, 160)
        BossBtn.Active = true
        BossBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 70)
        BossBtn.TextColor3 = Color3.fromRGB(180, 180, 255)
        task.spawn(RunGrindLoop)
    else
        ToggleBtn.Text = ">>  Start Grind"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 70)
        ToggleBtn.TextColor3 = Color3.fromRGB(180, 180, 255)
        BossScanEnabled = false
        BossPriority = false
        BossBtn.Active = false
        BossBtn.Text = ">>  World Boss Scanner: OFF"
        BossBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
        BossBtn.TextColor3 = Color3.fromRGB(100, 100, 130)
    end
end)

-- [[ TOGGLE BOSS SCANNER ]] --
BossBtn.MouseButton1Click:Connect(function()
    if ScriptKilled or not GrindEnabled then return end
    BossScanEnabled = not BossScanEnabled

    if BossScanEnabled then
        BossBtn.Text = "||  World Boss Scanner: ON"
        BossBtn.BackgroundColor3 = Color3.fromRGB(70, 50, 20)
        BossBtn.TextColor3 = Color3.fromRGB(255, 200, 80)
        task.spawn(RunBossScanner)
    else
        BossScanEnabled = false
        BossPriority = false
        BossBtn.Text = ">>  World Boss Scanner: OFF"
        BossBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 70)
        BossBtn.TextColor3 = Color3.fromRGB(180, 180, 255)
    end
end)

-- [[ KILL ]] --
KillBtn.MouseButton1Click:Connect(function()
    GrindEnabled = false
    BossScanEnabled = false
    KillScript()
    task.wait(ACTION_CD)
    ScreenGui:Destroy()
end)


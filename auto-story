            for _, data in pairs(LOADOUT.Stand) do
                if base == data.signature then
                    local standNode = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
                    if standNode then
                        CurrentStand = FormatStandLabel(standNode.Text or "")
                    else
                        CurrentStand = data.label
                    end
                end
            end
        end
    end
    UpdateLoadoutLabels()
end

-- ================================================================
-- [[ LOADOUT ENFORCEMENT ]]
-- ================================================================
local function FleeAnyActiveBattle()
    if IsInStoryBattle() then
        StoryUseSkill("Flee")
        task.wait(1)
    elseif IsInDungeonBattle() then
        TryFleeFromDungeon()
        task.wait(0.5)
    end
end

local function EnsureStyle(targetStyle)
    if CurrentStyle == targetStyle then return end
    FleeAnyActiveBattle()
    SwapStyle(1)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited += 0.3
        DetectLoadoutFromInventory()
        if CurrentStyle == targetStyle then return end
    end
end

local function EnsureStand(targetStand)
    if CurrentStand:upper():find(targetStand:upper(), 1, true) then return end
    local slot = FindStandSlot(targetStand)
    if not slot then return end
    FleeAnyActiveBattle()
    StandStorageAction:FireServer("Swap", slot)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited += 0.3
        DetectLoadoutFromInventory()
        if CurrentStand:upper():find(targetStand:upper(), 1, true) then return end
    end
end

local function EnforceStoryLoadout()
    if not IsInStoryBattle() then
        FleeAnyActiveBattle()
    end
    DetectLoadoutFromInventory()
    if PrestigeEnabled then
        EnsureStand("Tusk of U")
    end
    EnsureStyle("ULF")
end

local function EnforceDungeonLoadout()
    if not IsInDungeonBattle() then
        FleeAnyActiveBattle()
    end
    DetectLoadoutFromInventory()
    EnsureStand("Tusk of U")
    EnsureStyle("ULF")
end


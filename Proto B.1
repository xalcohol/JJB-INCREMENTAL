-- ================================================================
-- [[ SETTINGS FLOWS ]]
-- ================================================================
local function GetMovePool(standName, styleName)
    local pool = {}
    local styleKey = styleName
    if styleName == "ULF" then styleKey = "Ultimate Lifeform" end
    if standName and STAND_MOVES[standName] then
        for _, m in ipairs(STAND_MOVES[standName].moves) do table.insert(pool, m) end
    end
    if styleKey and STYLE_MOVES[styleKey] then
        for _, m in ipairs(STYLE_MOVES[styleKey].moves) do
            if m.statusType ~= "heal" then table.insert(pool, m) end
        end
    end
    return pool
end

local function BuildStandPickerList()
    local list = {}
    local eq = GetEquippedStandSlot()
    if eq and not eq.isEmpty then table.insert(list, eq) end
    for _, s in ipairs(ScanStandSlots()) do
        if not s.isEmpty then table.insert(list, s) end
    end
    return list
end

local function BuildStylePickerList()
    local list = {}
    local eq = GetEquippedStyleSlot()
    if eq and not eq.isEmpty then table.insert(list, eq) end
    for _, s in ipairs(ScanStyleSlots()) do
        if not s.isEmpty then table.insert(list, s) end
    end
    return list
end

local function RunStorySettingsFlow()
    local standList = BuildStandPickerList()
    ShowSlotPicker("Story - Select Stand", standList, function(s)
        CFG.storyStandName = s.baseName
        local storyMoves = GetMovePool(CFG.storyStandName, "Ultimate Lifeform")
        ShowPriorityBuilder("Priority - Enrico Pucci", storyMoves, CFG.pucciPriority, function(p1)
            CFG.pucciPriority = p1
            ShowPriorityBuilder("Priority - Tooru", storyMoves, CFG.tooruPriority, function(p2)
                CFG.tooruPriority = p2
                local wbStandList = BuildStandPickerList()
                ShowSlotPicker("World Boss - Select Stand", wbStandList, function(ws)
                    CFG.wbStandName = ws.baseName
                    local wbStyleList = BuildStylePickerList()
                    ShowSlotPicker("World Boss - Select Style", wbStyleList, function(wst)
                        CFG.wbStyleName = wst.baseName
                        local wbMoves = GetMovePool(CFG.wbStandName, CFG.wbStyleName)
                        ShowPriorityBuilder("Priority - World Boss", wbMoves, CFG.wbPriority, function(p3)
                            CFG.wbPriority = p3
                            ClosePopup()
                            SetStatus("Story config saved", RUNT)
                            task.delay(3, function() if not StoryEnabled then SetStatus("Idle") end end)
                        end)
                    end)
                end)
            end)
        end)
    end)
end


local function GetStoryEnemyName()
    local label = SafeGet(PlayerGui, table.unpack(ENEMY_NAME_PATH))
    return label and (label.Text or "") or ""
end

local function GetCurrentStoryName()
    local btn = SafeGet(PlayerGui, table.unpack(STORY_BTN_PATH))
    if not btn then return "" end
    -- scan btn and all descendants for the story name text, same as Proto A IsBokuNoRhythm
    local candidates = { btn }
    for _, obj in ipairs(btn:GetDescendants()) do
        table.insert(candidates, obj)
    end
    for _, obj in ipairs(candidates) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local t = obj.Text or ""
            if t ~= "" then return t end
        end
    end
    return ""
end

-- True when story button shows a post-prestige story OR current enemy is prestige-eligible
-- "Post-prestige" means: Heaven Averted (contains Pucci) or any story after it
local function ShouldPrestigeNow()
    -- check enemy name first (works mid-combat)
    local enemyName = GetStoryEnemyName()
    if enemyName ~= "" and PRESTIGE_ELIGIBLE_ENEMIES[enemyName] then return true end
    -- check story button text with exact table lookup
    local storyName = GetCurrentStoryName()
    if storyName ~= "" and POST_PRESTIGE_STORIES[storyName] then return true end
    -- fallback: partial match scan in case of formatting differences
    for name, _ in pairs(POST_PRESTIGE_STORIES) do
        if storyName:find(name, 1, true) then return true end
    end
    for name, _ in pairs(PRESTIGE_ELIGIBLE_ENEMIES) do
        if enemyName:find(name, 1, true) then return true end
    end
    return false
end

local function IsPucci()  return GetStoryEnemyName() == "Enrico Pucci" end
local function IsTooru()  return GetStoryEnemyName() == "Tooru"        end

local function EnemyUsesPucciConfig()
    return PUCCI_CONFIG_ENEMIES[GetStoryEnemyName()] == true
end

-- ================================================================
-- [[ NAME FORMATTING ]] -- identical to Proto A
-- ================================================================
local function StripRichText(text)
    local clean = text:gsub("<[^>]+>", "")
    clean = clean:gsub("%s+", " ")
    return clean:match("^%s*(.-)%s*$")
end

local function StripSlotPrefix(name)
    name = name:match("^S%d+:%s*(.+)$") or name
    name = name:match("^STAND:%s*(.+)$") or name
    name = name:match("^STYLE:%s*(.+)$") or name
    return name
end

local function FormatDropdownName(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    return clean:match("^%s*(.-)%s*$")
end

local STAND_ABBREV = {
    ["Tusk of U"]="TOU", ["Tusk Act 4"]="TA4",
    ["King Crimson Requiem"]="KCR", ["King of U"]="KOU",
}

local function FormatStandLabel(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    clean = clean:match("^%s*(.-)%s*$")

    local traitCount = {}
    local traitOrder = {}
    for trait in clean:gmatch("%[([A-Z]+)%]") do
        local initial = trait:sub(1,1)
        if not traitCount[initial] then
            table.insert(traitOrder, initial)
            traitCount[initial] = 0
        end
        traitCount[initial] += 1
    end

    local base = clean:gsub("%s*%[%u+%]",""):gsub("%s*&%s*",""):match("^%s*(.-)%s*$")

    local baseUpper = base:upper()
    for full, short in pairs(STAND_ABBREV) do
        if baseUpper == full:upper() then base = short; break end
    end

    local traitParts = {}
    for _, initial in ipairs(traitOrder) do
        local count = traitCount[initial]
        if count > 1 then table.insert(traitParts, initial .. count)
        else               table.insert(traitParts, initial) end
    end

    if #traitParts > 0 then
        return base .. " [" .. table.concat(traitParts, "+") .. "]"
    end
    return base
end

local function FormatBaseName(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    clean = clean:gsub("%s*%[.-%]",""):gsub("%s*&%s*",""):match("^%s*(.-)%s*$")
    local small = {of=true,the=true,a=true,an=true,["and"]=true}
    local words = {}
    for word in clean:lower():gmatch("%S+") do
        if #words == 0 or not small[word] then
            word = word:sub(1,1):upper() .. word:sub(2)
        end
        table.insert(words, word)
    end
    return table.concat(words, " ")
end

-- ================================================================
-- [[ SLOT SCANNERS ]]
-- ================================================================
local function ScanStandSlots()
    local container = SafeGet(PlayerGui, table.unpack(STAND_STORAGE_PATH))
    if not container then return {} end
    local slots = {}
    local slotNum = 0
    for i, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            slotNum = slotNum + 1
            local nameLabel = child:FindFirstChild("NameLabel")
            local rawText = nameLabel and (nameLabel.Text or "") or ""
            local name = FormatDropdownName(rawText)
            local swapArg = i == 1 and 1 or i - 1
            table.insert(slots, {
                slotNum     = slotNum,
                swapArg     = swapArg,
                displayName = "Slot " .. slotNum .. ": " .. FormatStandLabel(rawText),
                baseName    = FormatBaseName(rawText),
                isEmpty     = (name == "" or name:find("Locked") ~= nil),
            })
        end
    end
    return slots
end

local function ScanStyleSlots()
    local container = SafeGet(PlayerGui, table.unpack(STYLE_STORAGE_PATH))
    if not container then return {} end
    local slots = {}
    local slotNum = 0
    for i, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            slotNum = slotNum + 1
            local nameLabel = child:FindFirstChild("NameLabel")
            local rawText = nameLabel and (nameLabel.Text or "") or ""
            local name = FormatDropdownName(rawText)
            local swapArg = i == 1 and 1 or i - 1
            table.insert(slots, {
                slotNum     = slotNum,
                swapArg     = swapArg,
                displayName = "Slot " .. slotNum .. ": " .. FormatBaseName(rawText),
                baseName    = FormatBaseName(rawText),
                isEmpty     = (name == "" or name:find("Locked") ~= nil),
            })
        end
    end
    return slots
end

local function GetEquippedStandSlot()
    local lbl = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
    if not lbl then return nil end
    local rawText = lbl.Text or ""
    return {
        slotNum     = 0,
        swapArg     = nil,
        displayName = "Equipped: " .. FormatStandLabel(rawText),
        baseName    = FormatBaseName(rawText),
        isEmpty     = false,
        isEquipped  = true,
    }
end

local function GetEquippedStyleSlot()
    local lbl = SafeGet(PlayerGui, table.unpack(INV_STYLE_PATH))
    if not lbl then return nil end
    local rawText = lbl.Text or ""
    return {
        slotNum     = 0,
        swapArg     = nil,
        displayName = "Equipped: " .. FormatBaseName(rawText),
        baseName    = FormatBaseName(rawText),
        isEmpty     = false,
        isEquipped  = true,
    }
end

local function FindStandSlotByName(targetName)
    local slots = ScanStandSlots()
    for _, entry in ipairs(slots) do
        if entry.baseName:upper():find(targetName:upper(), 1, true) then
            return entry.swapArg
        end
    end
    return nil
end

local function FindStyleSlotByName(targetName)
    local slots = ScanStyleSlots()
    for _, entry in ipairs(slots) do
        if entry.baseName:upper():find(targetName:upper(), 1, true) then
            return entry.swapArg
        end
    end
    return nil
end


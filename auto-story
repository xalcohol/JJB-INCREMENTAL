    if hasStamina and CanUse(ctx,"Malevolent Shrine") then
        if not EnemyIsBleeding(ctx) then
            UseSkill(ctx,"Malevolent Shrine"); return
        end
    end

    if hasStamina and CanUse(ctx,"Melting Overdrive") then
        if not EnemyIsBurning(ctx) then
            UseSkill(ctx,"Melting Overdrive"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Absolute Energy") then
        if not PlayerHasStrengthBuff(ctx) then
            UseSkill(ctx,"Absolute Energy"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then
        UseSkill(ctx,"Infinite Rotation"); return
    end
    if hasEnergy and CanUse(ctx,"Raging Demon") then
        UseSkill(ctx,"Raging Demon"); return
    end

    if not hasEnergy and hasStamina then
        if     CanUse(ctx,"Melting Overdrive")  then UseSkill(ctx,"Melting Overdrive");  return
        elseif CanUse(ctx,"Malevolent Shrine")  then UseSkill(ctx,"Malevolent Shrine");  return
        else                                         UseSkill(ctx,"Rest");               return
        end
    end
    if hasEnergy and not hasStamina then
        if     CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return
        elseif CanUse(ctx,"Raging Demon")      then UseSkill(ctx,"Raging Demon");      return
        else                                        UseSkill(ctx,"Rest");              return
        end
    end

    UseSkill(ctx,"Rest")
end


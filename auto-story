local function IsBokuNoRhythm()
    local btn = SafeGet(StoryCtx.Root(), "ButtonContainer","StoryEncounterBtn")
    if not btn then return false end
    for _, obj in ipairs({ btn, table.unpack(btn:GetDescendants()) }) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            if (obj.Text or ""):find("Boku no Rhythm") then return true end
        end
    end
    return false
end

local function TryPrestige()
    FirePrestige()
    task.wait(ACTION_CD)
end

-- ================================================================
-- [[ AUTO STORY LOOP ]]
-- ================================================================
local function RunStoryLoop()
    DetectLoadoutFromInventory()
    EnsureULFForStory()
    TryFleeFromDungeon()
    task.wait(0.5)

    if IsInStoryBattle() then
        -- warn("[Story] Already in story battle — finishing first.")
        RunBattleLoop(StoryCtx, function() return StoryEnabled end, IsInStoryBattle)
        task.wait(ACTION_CD)
    end

    if PrestigeEnabled then
        TryPrestige()
        task.wait(ACTION_CD)
    end

    task.spawn(RunWorldBossScanner)

    while StoryEnabled and not ScriptKilled do
        if WorldBossPriority then
            -- warn("[Story] World boss priority — finishing open battle first.")
            if IsInStoryBattle() then
                RunBattleLoop(StoryCtx, function() return StoryEnabled end, IsInStoryBattle)
                task.wait(ACTION_CD)
            end
            RunWorldBossFight()
            task.wait(ACTION_CD)

        elseif PrestigeEnabled and IsBokuNoRhythm() then
            -- warn("[Story] Boku no Rhythm — Prestiging.")
            TryPrestige()
            task.wait(ACTION_CD)

        else
            CombatAction:FireServer("EngageStory")
            task.wait(ACTION_CD)
            RunBattleLoop(StoryCtx, function() return StoryEnabled end, IsInStoryBattle)
            task.wait(ACTION_CD)
        end

        task.wait(ACTION_CD)
    end
end

-- ================================================================
-- [[ AUTO DUNGEON LOOP ]]
-- ================================================================
local function RunDungeonLoop()
    DetectLoadoutFromInventory()

    if IsInStoryBattle() then
        -- warn("[Dungeon] In story battle — fleeing.")
        StoryUseSkill("Flee")
        task.wait(1)
    end

    while DungeonEnabled and not ScriptKilled do
        StartDungeon()
        task.wait(ACTION_CD)
        local waited = 0
        while not IsInDungeonBattle() and waited < 5 do
            task.wait(0.2); waited += 0.2
        end
        if IsInDungeonBattle() then
            RunBattleLoop(DungeonCtx, function() return DungeonEnabled end, IsInDungeonBattle)
        end
        task.wait(ACTION_CD)
    end
end


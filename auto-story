local DropdownOpen = false

local function CloseDropdown()
    DropdownOpen = false
    StandDropdown.Visible = false
    for _, child in ipairs(StandDropdown:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
end

local function OpenStandDropdown()
    if DropdownOpen then CloseDropdown(); return end

    local slots = ScanStandSlots()
    if #slots == 0 then return end

    for _, child in ipairs(StandDropdown:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local ENTRY_HEIGHT = 22
    local PADDING      = 2
    local MIN_WIDTH    = 160

    local maxLen = MIN_WIDTH
    for _, entry in ipairs(slots) do
        local estWidth = #entry.name * 7 + 16
        if estWidth > maxLen then maxLen = estWidth end
    end

    for i, entry in ipairs(slots) do
        local entryBtn = Instance.new("TextButton")
        entryBtn.Size = UDim2.new(1, -8, 0, ENTRY_HEIGHT)
        entryBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 48)
        entryBtn.TextColor3 = Color3.fromRGB(200, 200, 255)
        entryBtn.Text = entry.name
        entryBtn.TextSize = 10
        entryBtn.Font = Enum.Font.Gotham
        entryBtn.BorderSizePixel = 0
        entryBtn.TextXAlignment = Enum.TextXAlignment.Center
        entryBtn.LayoutOrder = i
        entryBtn.ZIndex = 11
        entryBtn.Parent = StandDropdown
        do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,4); c.Parent = entryBtn end

        local slotNum = entry.slot
        entryBtn.MouseButton1Click:Connect(function()
            if not slotNum then return end
            if IsInStoryBattle() then
                StoryUseSkill("Flee"); task.wait(1)
            elseif IsInDungeonBattle() then
                TryFleeFromDungeon(); task.wait(0.5)
            end
            StandStorageAction:FireServer("Swap", slotNum)
            task.wait(0.3)
            DetectLoadoutFromInventory()
            CloseDropdown()
        end)
    end

    local totalHeight = (#slots * (ENTRY_HEIGHT + PADDING)) + 6
    StandDropdown.Size = UDim2.new(0, maxLen, 0, totalHeight)
    StandDropdown.Visible = true
    DropdownOpen = true
end

-- ================================================================
-- [[ SHARED SURVIVAL CHECK ]]
-- ================================================================
local function HandleSurvival(ctx)
    local _, _, hpPct = GetHP(ctx)

    if hpPct < HP_DANGER then
        if     CanUse(ctx,"Instant Reformation") then UseSkill(ctx,"Instant Reformation")
        elseif CanUse(ctx,"Block")               then UseSkill(ctx,"Block")
        else                                          UseSkill(ctx,"Rest")
        end
        return true
    end

    if hpPct < HP_HEAL then
        if CanUse(ctx,"Instant Reformation") then
            ctx.HasBlockedThisDip = false
            UseSkill(ctx,"Instant Reformation")
            return true
        end
        if not ctx.HasBlockedThisDip then
            ctx.HasBlockedThisDip = true
            if CanUse(ctx,"Block") then
                UseSkill(ctx,"Block")
                return true
            end
        end
    else
        ctx.HasBlockedThisDip = false
    end

    return false
end

-- ================================================================
-- [[ COMBAT ENGINE — STORY ]]
-- Tooru (prestige OFF): Illusory Presence -> Rain of Debris ->
--   Golden Spin -> Melting Overdrive -> Infinite Rotation
-- Full rotation enemies: Illusory Presence -> Golden Spin ->
--   Infinite Rotation
-- All others: Infinite Rotation only
-- ================================================================
local function RunStoryCombatTick()
    local ctx             = StoryCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= STORY_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    -- Tooru-specific engine (prestige OFF only)
    if IsTooru() and not PrestigeEnabled then
        if hasEnergy and CanUse(ctx,"Illusory Presence") then
            if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
                UseSkill(ctx,"Illusory Presence"); return
            end
        end
        if hasEnergy and CanUse(ctx,"Rain of Debris") then
            UseSkill(ctx,"Rain of Debris"); return
        end
        if hasEnergy and CanUse(ctx,"Golden Spin") then
            if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
                UseSkill(ctx,"Golden Spin"); return
            end
        end
        if hasStamina and CanUse(ctx,"Melting Overdrive") then
            if not EnemyIsBurning(ctx) then
                UseSkill(ctx,"Melting Overdrive"); return
            end
        end
        if hasEnergy and CanUse(ctx,"Infinite Rotation") then
            UseSkill(ctx,"Infinite Rotation"); return
        end
        UseSkill(ctx,"Rest"); return
    end

    -- Standard full rotation (Enrico Pucci + post-prestige enemies)
    if StoryEnemyUsesFullRotation() then
        if hasEnergy and CanUse(ctx,"Illusory Presence") then
            if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
                UseSkill(ctx,"Illusory Presence"); return
            end
        end
        if hasEnergy and CanUse(ctx,"Golden Spin") then
            if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
                UseSkill(ctx,"Golden Spin"); return
            end
        end
    end

    -- Normal attack filler
    if hasEnergy and CanUse(ctx,"Infinite Rotation") then
        UseSkill(ctx,"Infinite Rotation"); return
    end

    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ COMBAT ENGINE — DUNGEON ]]
-- TOU + ULF. Energy threshold 40, stamina threshold 20.
-- Illusory Presence -> Golden Spin -> Melting Overdrive ->
-- Infinite Rotation
-- ================================================================
local function RunDungeonCombatTick()
    local ctx             = DungeonCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= DUNGEON_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if hasEnergy and CanUse(ctx,"Illusory Presence") then
        if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
            UseSkill(ctx,"Illusory Presence"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Golden Spin") then
        if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
            UseSkill(ctx,"Golden Spin"); return
        end
    end

    if hasStamina and CanUse(ctx,"Melting Overdrive") then
        if not EnemyIsBurning(ctx) then
            UseSkill(ctx,"Melting Overdrive"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then
        UseSkill(ctx,"Infinite Rotation"); return
    end

    if not hasEnergy and hasStamina then
        if CanUse(ctx,"Melting Overdrive") then UseSkill(ctx,"Melting Overdrive"); return end
        UseSkill(ctx,"Rest"); return
    end

    if hasEnergy and not hasStamina then
        if CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
        UseSkill(ctx,"Rest"); return
    end

    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ COMBAT ENGINE — WORLD BOSS ]]
-- TOU + Shrine enforced.
-- Illusory Presence -> Rain of Debris -> Golden Spin ->
-- Malevolent Shrine (bleed <= 1) -> Divine Flame (burn <= 1) ->
-- Infinite Rotation filler
-- ================================================================
local function RunWorldBossTick()
    local ctx             = WorldBossCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= STORY_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if hasEnergy and CanUse(ctx,"Illusory Presence") then
        if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
            UseSkill(ctx,"Illusory Presence"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Rain of Debris") then
        UseSkill(ctx,"Rain of Debris"); return
    end

    if hasEnergy and CanUse(ctx,"Golden Spin") then
        if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
            UseSkill(ctx,"Golden Spin"); return
        end
    end

    if hasStamina and CanUse(ctx,"Malevolent Shrine") then
        if EnemyStatusDur(ctx,"Bleed") <= 1 then
            UseSkill(ctx,"Malevolent Shrine"); return
        end
    end

    if hasStamina and CanUse(ctx,"Divine Flame") then
        if EnemyStatusDur(ctx,"Burn") <= 1 then
            UseSkill(ctx,"Divine Flame"); return
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then
        UseSkill(ctx,"Infinite Rotation"); return
    end

    if not hasEnergy and hasStamina then
        if     CanUse(ctx,"Malevolent Shrine") then UseSkill(ctx,"Malevolent Shrine"); return
        elseif CanUse(ctx,"Divine Flame")      then UseSkill(ctx,"Divine Flame");      return
        else                                        UseSkill(ctx,"Rest");              return
        end
    end

    if hasEnergy and not hasStamina then
        if CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
        UseSkill(ctx,"Rest"); return
    end

    UseSkill(ctx,"Rest")
end


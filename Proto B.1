-- ================================================================
-- [[ PRIORITY BUILDER ]]
-- ================================================================
local function ShowPriorityBuilder(title, moves, currentPrio, onSave)
    local w = WIN_W - 28
    local h = 278
    OpenPopup(w, h)
    local y = PopupHeader(title)

    local ordered = {}
    for _, mn in ipairs(currentPrio or {}) do
        for _, m in ipairs(moves) do
            if m.name == mn then table.insert(ordered, m); break end
        end
    end

    local function GetPool()
        local pool = {}
        for _, m in ipairs(moves) do
            local found = false
            for _, om in ipairs(ordered) do
                if om.name == m.name then found = true; break end
            end
            if not found then table.insert(pool, m) end
        end
        return pool
    end

    local avlL = Instance.new("TextLabel", PopupFrame)
    avlL.Size = UDim2.new(0.5,-8,0,14); avlL.Position = UDim2.new(0,9,0,y)
    avlL.BackgroundTransparency = 1; avlL.Text = "Available"
    avlL.TextColor3 = TSUB; avlL.TextSize = 9; avlL.Font = Enum.Font.GothamBold
    avlL.TextXAlignment = Enum.TextXAlignment.Left; avlL.ZIndex = 32

    local prioL = Instance.new("TextLabel", PopupFrame)
    prioL.Size = UDim2.new(0.5,-8,0,14); prioL.Position = UDim2.new(0.5,1,0,y)
    prioL.BackgroundTransparency = 1; prioL.Text = "Priority"
    prioL.TextColor3 = TSUB; prioL.TextSize = 9; prioL.Font = Enum.Font.GothamBold
    prioL.TextXAlignment = Enum.TextXAlignment.Left; prioL.ZIndex = 32
    y = y + 16

    local LIST_H = 152

    local function MakeListFrame(xScale, xOff)
        local f = Instance.new("Frame", PopupFrame)
        f.Size = UDim2.new(0.5,-10,0,LIST_H); f.Position = UDim2.new(xScale,xOff,0,y)
        f.BackgroundColor3 = BG3; f.BorderSizePixel = 0
        f.ClipsDescendants = true; f.ZIndex = 32
        do local c = Instance.new("UICorner", f); c.CornerRadius = UDim.new(0,6) end
        local layout = Instance.new("UIListLayout", f)
        layout.SortOrder = Enum.SortOrder.LayoutOrder; layout.Padding = UDim.new(0,2)
        local pad = Instance.new("UIPadding", f)
        pad.PaddingTop = UDim.new(0,3); pad.PaddingLeft = UDim.new(0,3); pad.PaddingRight = UDim.new(0,3)
        return f
    end

    local poolF  = MakeListFrame(0, 9)
    local queueF = MakeListFrame(0.5, 1)

    local RebuildPool
    local RebuildQueue

    RebuildQueue = function()
        for _, child in ipairs(queueF:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextButton") then child:Destroy() end
        end
        for i, m in ipairs(ordered) do
            local row = Instance.new("Frame", queueF)
            row.Size = UDim2.new(1,0,0,24); row.BackgroundColor3 = BG4
            row.BorderSizePixel = 0; row.LayoutOrder = i; row.ZIndex = 33
            do local c = Instance.new("UICorner", row); c.CornerRadius = UDim.new(0,5) end

            local numLbl = Instance.new("TextLabel", row)
            numLbl.Size = UDim2.new(0,14,1,0); numLbl.Position = UDim2.new(0,3,0,0)
            numLbl.BackgroundTransparency = 1; numLbl.Text = i.."."
            numLbl.TextColor3 = ACCENT; numLbl.TextSize = 9; numLbl.Font = Enum.Font.GothamBold
            numLbl.ZIndex = 34

            local nmLbl = Instance.new("TextLabel", row)
            nmLbl.Size = UDim2.new(1,-34,1,0); nmLbl.Position = UDim2.new(0,18,0,0)
            nmLbl.BackgroundTransparency = 1; nmLbl.Text = m.name
            nmLbl.TextColor3 = TPRIM; nmLbl.TextSize = 9; nmLbl.Font = Enum.Font.Gotham
            nmLbl.TextTruncate = Enum.TextTruncate.AtEnd; nmLbl.ZIndex = 34

            local rmBtn = Instance.new("TextButton", row)
            rmBtn.Size = UDim2.new(0,16,0,16); rmBtn.Position = UDim2.new(1,-18,0.5,-8)
            rmBtn.BackgroundColor3 = Color3.fromRGB(60,14,14); rmBtn.TextColor3 = PAUT
            rmBtn.Text = "X"; rmBtn.TextSize = 8; rmBtn.Font = Enum.Font.GothamBold
            rmBtn.BorderSizePixel = 0; rmBtn.ZIndex = 34
            do local c = Instance.new("UICorner", rmBtn); c.CornerRadius = UDim.new(0,3) end

            local ci = i
            rmBtn.MouseButton1Click:Connect(function()
                table.remove(ordered, ci)
                RebuildPool(); RebuildQueue()
            end)
        end
    end

    RebuildPool = function()
        for _, child in ipairs(poolF:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        local pool = GetPool()
        for pi, pm in ipairs(pool) do
            local pb = Instance.new("TextButton", poolF)
            pb.Size = UDim2.new(1,0,0,24); pb.BackgroundColor3 = BG4
            pb.TextColor3 = TPRIM; pb.Text = pm.name; pb.TextSize = 9
            pb.Font = Enum.Font.Gotham; pb.TextTruncate = Enum.TextTruncate.AtEnd
            pb.BorderSizePixel = 0; pb.LayoutOrder = pi; pb.ZIndex = 33
            do local c = Instance.new("UICorner", pb); c.CornerRadius = UDim.new(0,5) end
            local captured = pm
            pb.MouseButton1Click:Connect(function()
                table.insert(ordered, captured); pb:Destroy(); RebuildQueue()
            end)
        end
    end

    RebuildPool(); RebuildQueue()

    local saveBtn = Instance.new("TextButton", PopupFrame)
    saveBtn.Size = UDim2.new(1,-18,0,28); saveBtn.Position = UDim2.new(0,9,0,y+LIST_H+6)
    saveBtn.BackgroundColor3 = ACCENT2; saveBtn.TextColor3 = TPRIM
    saveBtn.Text = "Save Priority"; saveBtn.TextSize = 11; saveBtn.Font = Enum.Font.GothamBold
    saveBtn.BorderSizePixel = 0; saveBtn.ZIndex = 32
    do
        local c = Instance.new("UICorner", saveBtn); c.CornerRadius = UDim.new(0,7)
        local s = Instance.new("UIStroke", saveBtn); s.Color = ACCENT; s.Thickness = 1
    end
    saveBtn.MouseButton1Click:Connect(function()
        local result = {}
        for _, m in ipairs(ordered) do table.insert(result, m.name) end
        onSave(result)
    end)
end


local function RunBattleLoop(ctx, enabledFlag, inBattleFn)
    ctx.HasBlockedThisDip = false
    task.wait(0.5)
    ConfirmLoadoutInCombat(ctx)
    while enabledFlag() and not ScriptKilled and inBattleFn() do
        RunCombatTick(ctx)
        task.wait(ACTION_CD)
    end
    ctx.HasBlockedThisDip = false
end

-- ================================================================
-- [[ WORLD BOSS HELPERS ]]
-- ================================================================
local function ParseTimerLabel()
    local label = SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame",
        "MainPanel","InnerContent","ContentArea","WorldBossFrame",
        "MenuContainer","InfoCard","TimerLabel"
    )
    if not label then return nil end
    local mins, secs = (label.Text or ""):match("(%d+):(%d+)")
    if not mins then return nil end
    return tonumber(mins) * 60 + tonumber(secs)
end

local function GetEngageBtnText()
    local btn = SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame",
        "MainPanel","InnerContent","ContentArea","WorldBossFrame",
        "MenuContainer","InfoCard","EngageBtn"
    )
    return btn and (btn.Text or "") or ""
end

local function GetBossNameText()
    local lbl = SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame",
        "MainPanel","InnerContent","ContentArea","WorldBossFrame",
        "MenuContainer","InfoCard","BossNameLabel"
    )
    return lbl and (lbl.Text or "") or ""
end

local function WaitForBossTimer()
    while StoryEnabled and not ScriptKilled do
        local secs = ParseTimerLabel()

        if not secs or secs <= 0 then
            return
        end

        if secs > 30 * 60 then
            -- warn(string.format("[WorldBoss] Timer %ds (>30min) — sleeping 30min then rechecking.", secs))
            local elapsed = 0
            while elapsed < 1800 and StoryEnabled and not ScriptKilled do
                task.wait(1); elapsed += 1
            end

        elseif secs > 10 * 60 then
            -- warn(string.format("[WorldBoss] Timer %ds (>10min) — sleeping 10min then rechecking.", secs))
            local elapsed = 0
            while elapsed < 600 and StoryEnabled and not ScriptKilled do
                task.wait(1); elapsed += 1
            end

        else
            -- warn(string.format("[WorldBoss] Timer %ds (≤10min) — waiting exact duration.", secs))
            local elapsed = 0
            while elapsed < secs and StoryEnabled and not ScriptKilled do
                task.wait(1); elapsed += 1
            end
            return
        end
    end
end

-- ================================================================
-- [[ WORLD BOSS SCANNER ]]
-- ================================================================
local function RunWorldBossScanner()
    -- Check immediately on start in case a boss is already available
    local engageText = GetEngageBtnText()
    if not engageText:find("ENGAGE BOSS") then
        -- No boss up yet — wait for the timer
        WaitForBossTimer()
    end

    while StoryEnabled and not ScriptKilled do
        local engageText = GetEngageBtnText()

        if engageText:find("ENGAGE BOSS") then
            -- warn("[WorldBoss] Boss available — flagging priority.")
            WorldBossPriority = true
            while WorldBossPriority and StoryEnabled and not ScriptKilled do
                task.wait(1)
            end
            task.wait(10)
            WaitForBossTimer()

        elseif engageText:find("ALREADY FOUGHT") then
            -- warn("[WorldBoss] Already fought this cycle.")
            task.wait(5)
            WaitForBossTimer()

        else
            task.wait(5)
            WaitForBossTimer()
        end
    end
end

-- ================================================================
-- [[ WORLD BOSS FIGHT ROUTINE ]]
-- ================================================================
local function RunWorldBossFight()
    PreBossStand = CurrentStand
    PreBossStyle = CurrentStyle

    -- If KOU, swap to Shrine for optimal bleed stacking
    -- (KOU has 10% passive burn chance making Melting Overdrive redundant)
    if CurrentStand == "King of U" and CurrentStyle ~= "Shrine" then
        SwapStyle(1)
        local waited = 0
        while waited < 5 do
            task.wait(0.3); waited += 0.3
            DetectLoadoutFromInventory()
            if CurrentStyle == "Shrine" then break end
        end
    end

    -- warn(string.format("[WorldBoss] Engaging — %s + %s", CurrentStand, CurrentStyle))

    EngageWorldBoss()

    local turnLabel = SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame",
        "MainPanel","InnerContent","ContentArea","WorldBossFrame",
        "CombatMainFrame","TurnLabel"
    )

    local waited       = 0
    local fightStarted = false
    while waited < 8 and not ScriptKilled do
        task.wait(0.3); waited += 0.3
        if turnLabel and (turnLabel.Text or ""):find("Turns Remaining: 10/10") then
            fightStarted = true
            break
        end
    end

    if not fightStarted then
        -- warn("[WorldBoss] Fight start unconfirmed — firing fallback attack.")
        WorldBossUseSkill("Infinite Rotation")
        task.wait(1)
    end

    local logText = SafeGet(PlayerGui,
        "JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame",
        "MainPanel","InnerContent","ContentArea","WorldBossFrame",
        "CombatMainFrame","ContentContainer","ChatboxArea","ChatScroll","LogText"
    )

    WorldBossCtx.HasBlockedThisDip = false
    task.wait(0.5)
    ConfirmLoadoutInCombat(WorldBossCtx)

    local elapsed  = 0
    local finished = false

    while elapsed < 120 and not ScriptKilled do
        if logText then
            local log = logText.Text or ""
            if log:find("Damage Dealt:") or log:find("Loot Secured") then
                finished = true
                break
            end
        end
        RunWorldBossTick()
        task.wait(ACTION_CD)
        elapsed += ACTION_CD
    end

    WorldBossCtx.HasBlockedThisDip = false

    if CurrentStyle ~= PreBossStyle then
        SwapStyle(1); task.wait(0.5)
    end
    if CurrentStand ~= PreBossStand then
        SwapStand(1); task.wait(0.5)
    end
    if CurrentStyle ~= PreBossStyle or CurrentStand ~= PreBossStand then
        DetectLoadoutFromInventory()
    end

    WorldBossPriority = false
end

